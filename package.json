{
  "name": "thefutureofman",
  "version": "1.0.0",
  "description": "The Future of Man is a web-based quiz application designed to provide users with a fun, introspective experience. Users answer a series of moral and personality-driven questions and receive personalized results that place them in one of three categories: Heaven, Hell, or In-Between. The application includes both a user-facing frontend and a secure admin backend for managing content and analyzing results.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"magenta,cyan\" --prefix \"[{time}] [{name}]\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "format": "prettier --write \"client/**/*.{js,ts,tsx,json,css,md}\" \"server/**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"client/**/*.{js,ts,tsx,json,css,md}\" \"server/**/*.{js,ts,json,md}\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markmuthii/the-future-of-man.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/markmuthii/the-future-of-man/issues"
  },
  "homepage": "https://github.com/markmuthii/the-future-of-man#readme",
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "nodemon": "^3.1.10",
    "prettier": "3.5.3"
  },
  "lint-staged": {
    "client/**/*.{js,ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "server/**/*.{js,ts,json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "@digicroz/react-floating-whatsapp": "^1.0.2",
    "@paystack/inline-js": "^2.22.7",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "canvas-confetti": "^1.9.4",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.2.2",
    "mongodb": "^6.20.0",
    "node-fetch": "^3.3.2",
    "paystack": "^2.0.1",
    "react-paystack": "^6.0.0"
  }
}
